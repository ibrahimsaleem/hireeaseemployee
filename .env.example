# ─── Employee Portal Backend ─────────────────────────────────────────────────
# Copy this file to .env (never commit .env)

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
NODE_TLS_REJECT_UNAUTHORIZED=0
SESSION_SECRET=change-this-to-a-long-random-string

# Gemini AI (for resume tailoring)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_API_KEY_2=your-fallback-gemini-api-key
GEMINI_PUBLIC_MODEL=gemini-2.5-flash

# Backend server port
PORT=3001

# ─── Employee Portal Frontend ─────────────────────────────────────────────────
# URL of THIS backend (not the main Aplyease backend)
# Local dev:
VITE_API_URL=http://localhost:3001
# Production (after deploying server to Render):
# VITE_API_URL=https://your-employee-api.onrender.com
